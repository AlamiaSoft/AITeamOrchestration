# Use the official MetaGPT image as base so we don't compile heavy AI packages (like faiss, lancedb) from source on ARM!
FROM metagpt/metagpt:latest

# MetaGPT is already installed in this image. We just need Gradio for the UI.
RUN pip install --no-cache-dir gradio==2.3.6

# The source code will be mounted from the git-sync volume
CMD ["tail", "-f", "/dev/null"]
